{
  "manifest_version": 3,
  "name": "AegisAI Prompt Protector",
  "version": "1.0",
  "description": "Detects sensitive information in prompts before sending to AI models.",
  "permissions": ["activeTab"],
  "host_permissions": ["<all_urls>"],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],

  "action": {
    "default_popup": "popup.html"
  }
}